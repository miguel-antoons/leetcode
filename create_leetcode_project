#!/usr/bin/env python3
"""Create a LeetCode project structure from a problem title."""

import os
import re
import sys


def sanitize_title(title: str) -> str:
    """Remove spaces and special characters from the title."""
    # Replace spaces and dots with underscores
    sanitized = re.sub(r'[^a-zA-Z0-9]', '_', title)
    # Remove consecutive underscores
    sanitized = re.sub(r'_+', '_', sanitized)
    # Remove leading/trailing underscores
    sanitized = sanitized.strip('_')
    # If the name starts with a digit, prefix with s_
    if sanitized and sanitized[0].isdigit():
        sanitized = f's_{sanitized}'
    return sanitized


def add_to_workspace_members(dir_name: str):
    """Add the new project to the root Cargo.toml workspace members."""
    root_cargo_path = 'Cargo.toml'
    
    if not os.path.exists(root_cargo_path):
        # Create a new workspace Cargo.toml if it doesn't exist
        with open(root_cargo_path, 'w') as f:
            f.write(f'[workspace]\nmembers = ["{dir_name}"]\n')
        return
    
    # Read the existing Cargo.toml
    with open(root_cargo_path, 'r') as f:
        content = f.read()
    
    # Check if workspace section exists
    if '[workspace]' not in content:
        # Add workspace section at the end
        with open(root_cargo_path, 'a') as f:
            f.write(f'\n[workspace]\nmembers = ["{dir_name}"]\n')
        return
    
    # Find the members array using regex that handles multi-line arrays
    members_pattern = r'(members\s*=\s*\[)([^\]]*)(\])'
    match = re.search(members_pattern, content, re.DOTALL)
    
    if not match:
        # No members array found, add it after [workspace]
        content = content.replace('[workspace]', f'[workspace]\nmembers = ["{dir_name}"]')
    else:
        _ = match.group(1)
        members_content = match.group(2)
        _ = match.group(3)
        
        # Find all quoted strings in the members content (handles both single and multi-line)
        existing_members = re.findall(r'"([^"]+)"', members_content)
        
        # Add new member if not already present
        if dir_name not in existing_members:
            existing_members.append(dir_name)
            existing_members.sort()
        
        # Check if original was multi-line (has newlines in the content between brackets)
        is_multiline = '\n' in members_content
        
        # Rebuild the members array
        if len(existing_members) == 1:
            new_members = f'members = ["{existing_members[0]}"]'
        elif is_multiline:
            # Use proper TOML multi-line array format
            new_members_lines = ['members = [']
            for m in existing_members:
                new_members_lines.append(f'    "{m}",')
            new_members_lines.append(']')
            new_members = '\n'.join(new_members_lines)
        else:
            # Single-line format
            members_str = ', '.join(f'"{m}"' for m in existing_members)
            new_members = f'members = [{members_str}]'
        
        # Replace the old members array with the new one
        content = content[:match.start()] + new_members + content[match.end():]
    
    # Normalize excessive whitespace
    content = re.sub(r'\n{3,}', '\n\n', content)
    
    with open(root_cargo_path, 'w') as f:
        f.write(content)


def create_project_structure(title: str) -> str:
    """Create the project directory and files."""
    # Sanitize the title for the directory name
    dir_name = sanitize_title(title)
    
    # Create directory
    os.makedirs(dir_name, exist_ok=True)
    
    # Create src directory
    src_dir = os.path.join(dir_name, 'src')
    os.makedirs(src_dir, exist_ok=True)
    
    # Create tests directory (Cargo expects plural 'tests')
    test_dir = os.path.join(dir_name, 'tests')
    os.makedirs(test_dir, exist_ok=True)
    
    # Create lib.rs with Solution struct (as a library)
    lib_rs_content = """// LeetCode problem: {title}

pub struct Solution;

impl Solution {{
    // Your solution methods here
}}
""".format(title=title)
    
    with open(os.path.join(src_dir, 'lib.rs'), 'w') as f:
        f.write(lib_rs_content)
    
    # Create main.rs with simple entry point
    main_rs_content = """// LeetCode problem: {title}

fn main() {{
    println!("Hello, LeetCode!");
}}
""".format(title=title)
    
    with open(os.path.join(src_dir, 'main.rs'), 'w') as f:
        f.write(main_rs_content)
    
    # Create tests/test.rs with dummy integration test
    test_rs_content = """use {dir_name}::Solution;

#[test]
fn test_placeholder() {{
    // Placeholder test - replace with your actual tests
    assert!(true);
}}
""".format(dir_name=dir_name)
    
    with open(os.path.join(test_dir, 'test.rs'), 'w') as f:
        f.write(test_rs_content)
    
    # Create Cargo.toml
    cargo_toml_content = """[package]
name = "{dir_name}"
version = "0.1.0"
edition = "2021"

[dependencies]
""".format(dir_name=dir_name)
    
    with open(os.path.join(dir_name, 'Cargo.toml'), 'w') as f:
        f.write(cargo_toml_content)
    
    # Create REPORT.md
    report_content = "# {title}\n\n## Solution\n\n## Approach\n\n## Complexity Analysis\n\n## Test Cases\n".format(title=title)
    
    with open(os.path.join(dir_name, 'REPORT.md'), 'w') as f:
        f.write(report_content)
    
    return dir_name


def main():
    if len(sys.argv) < 2:
        print("Usage: ./create_leetcode_project <problem_title>")
        print("Example: ./create_leetcode_project '2236. Root Equals Sum of Children'")
        sys.exit(1)
    
    title = sys.argv[1]
    
    try:
        dir_name = create_project_structure(title)
        add_to_workspace_members(dir_name)
        print(f"Created project structure in '{dir_name}/'")
        print(f"  - {dir_name}/Cargo.toml")
        print(f"  - {dir_name}/src/main.rs")
        print(f"  - {dir_name}/src/lib.rs")
        print(f"  - {dir_name}/tests/test.rs")
        print(f"  - {dir_name}/REPORT.md")
        print(f"  - Added '{dir_name}' to root Cargo.toml workspace members")
    except Exception as e:
        print(f"Error: {e}")
        sys.exit(1)


if __name__ == '__main__':
    main()
